# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google Calendar API (for future calendar sync)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_API_KEY=your-google-api-key
# Optional NoCodeBackend auth proxy (server/runtime only for secrets)
# Set VITE_AUTH_PROVIDER=nocodebackend to use the same-origin /api/auth proxy.
VITE_AUTH_PROVIDER=mock
VITE_AUTH_PROXY_URL=/api/auth
NCB_API_BASE_URL=https://your-nocodebackend-api.example.com
NCB_SECRET_KEY=your-server-only-secret-key
